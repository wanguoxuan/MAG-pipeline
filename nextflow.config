/*
 * MAG Binning Pipeline — Nextflow Configuration
 */

// Global default params
params {
    sample_sheet         = null
    output_dir           = "./results"
    conda_env_dir        = "${HOME}/.nextflow/conda"

    // QC & Trimming
    fastp_min_qual       = 20
    fastp_min_len        = 50
    fastp_cpus           = 8

    // Host removal (optional)
    host_index           = null
    bowtie2_cpus         = 24

    // Assembly
    min_contig_len       = 500
    megahit_cpus         = 24

    // Binning — MetaBat2
    metabat2_min_contig  = 1500
    metabat2_cpus        = 16

    // Binning — MaxBin2
    maxbin2_min_contig   = 1500
    maxbin2_cpus         = 16

    // Binning — CONCOCT
    concoct_chunk_size   = 10000
    concoct_min_contig   = 1000
    concoct_cpus         = 16

    // Bin refinement — DAS Tool
    dastool_score_threshold = 0.5
    dastool_cpus            = 16

    // Quality check — CheckM2
    checkm2_db           = null
    checkm2_cpus         = 16

    // Taxonomy — GTDB-Tk
    gtdbtk_db            = null
    gtdbtk_cpus          = 32

    // Misc
    skip_summary         = false
    skip_gtdbtk          = false
    max_memory           = 120.GB
    max_cpus             = 48
    max_time             = 48.h
    queue_size           = 2      // Max concurrent jobs
    help                 = false
}

// Process resource labels
process {
    cpus   = 1
    memory = 4.GB
    time   = 3.h

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 3
    maxErrors     = '-1'

    withLabel: process_low {
        cpus   = 2
        memory = 8.GB
        time   = 4.h
    }
    withLabel: process_medium {
        cpus   = 8
        memory = 32.GB
        time   = 12.h
    }
    withLabel: process_high {
        cpus   = { params.megahit_cpus }
        memory = 120.GB
        time   = 48.h
    }
    // GTDB-Tk needs ~200 GB RAM to load the reference tree
    withLabel: process_gtdbtk {
        cpus   = { params.gtdbtk_cpus }
        memory = 200.GB
        time   = 48.h
    }
}

// Execution profiles
profiles {

    // Local execution with conda
    standard {
        conda.enabled  = true
        conda.useMamba = true

        executor {
            queueSize = params.queue_size
        }

        process {
            withName: FASTP {
                conda = "bioconda::fastp=1.0.1"
            }
            withName: BOWTIE2_HOST_REMOVE {
                conda = "bioconda::bowtie2=2.4.5 bioconda::samtools=1.15.1"
            }
            withName: MEGAHIT {
                conda = "bioconda::megahit=1.2.9"
            }
            withName: BOWTIE2_MAP {
                conda = "bioconda::bowtie2=2.4.5 bioconda::samtools=1.15.1"
            }
            withName: 'JGI_DEPTH|METABAT2' {
                conda = "bioconda::metabat2=2.15"
            }
            withName: MAXBIN2 {
                conda = "bioconda::maxbin2=2.2.7"
            }
            withName: CONCOCT {
                conda = "bioconda::concoct=1.1.0"
            }
            withName: DASTOOL {
                conda = "bioconda::das_tool=1.1.6"
            }
            withName: CHECKM2 {
                conda = "bioconda::checkm2=1.1.0"
            }
            withName: GTDBTK {
                conda = "bioconda::gtdbtk=2.4.1"
            }
            withName: 'SUMMARIZE.*|MERGE.*' {
                conda = "conda-forge::bash=5.1"
            }
        }
    }

    // HPC with module system
    modules {
        process {
            executor      = 'pbspro'
            queue         = 'normal'
            clusterOptions = '-P 14001280'
            beforeScript  = 'module load miniforge3/23.10 && conda activate base'

            withName: FASTP {
                conda = "${params.conda_env_dir}/fastp"
            }
            withName: BOWTIE2_HOST_REMOVE {
                conda = "${params.conda_env_dir}/bowtie2_samtools"
            }
            withName: MEGAHIT {
                conda = "${params.conda_env_dir}/megahit"
            }
            withName: BOWTIE2_MAP {
                conda = "${params.conda_env_dir}/bowtie2_samtools"
            }
            withName: 'JGI_DEPTH|METABAT2' {
                conda = "${params.conda_env_dir}/metabat2"
            }
            withName: MAXBIN2 {
                conda = "${params.conda_env_dir}/maxbin2"
            }
            withName: CONCOCT {
                conda = "${params.conda_env_dir}/concoct"
            }
            withName: DASTOOL {
                conda = "${params.conda_env_dir}/das_tool"
            }
            withName: CHECKM2 {
                conda = "${params.conda_env_dir}/checkm2"
            }
            withName: GTDBTK {
                conda = "${params.conda_env_dir}/gtdbtk"
            }
            withLabel: process_low {
                clusterOptions = '-P 14001280 -l select=1:ncpus=2:mem=16gb'
            }
            withLabel: process_medium {
                clusterOptions = '-P 14001280 -l select=1:ncpus=8:mem=64gb'
            }
            withLabel: process_high {
                clusterOptions = '-P 14001280 -l select=1:ncpus=24:mem=120gb'
            }
            withLabel: process_gtdbtk {
                clusterOptions = '-P 14001280 -l select=1:ncpus=24:mem=200gb'
            }
        }

        executor {
            queueSize       = 3
            submitRateLimit = '10 sec'
        }

        conda.enabled  = true
        conda.useMamba = true
    }

    // PBS with conda
    pbs {
        process {
            executor      = 'pbspro'
            queue         = 'normal'
            clusterOptions = '-P 14001280'
            beforeScript  = 'module load miniforge3/23.10 && conda activate base'

            withLabel: process_low {
                clusterOptions = '-P 14001280 -l select=1:ncpus=2:mem=16gb'
            }
            withLabel: process_medium {
                clusterOptions = '-P 14001280 -l select=1:ncpus=8:mem=64gb'
            }
            withLabel: process_high {
                clusterOptions = '-P 14001280 -l select=1:ncpus=24:mem=120gb'
            }
            withLabel: process_gtdbtk {
                clusterOptions = '-P 14001280 -l select=1:ncpus=24:mem=200gb'
            }
        }

        executor {
            queueSize       = 3
            submitRateLimit = '10 sec'
        }

        conda.enabled  = true
        conda.useMamba = true
    }

    // Testing
    test {
        params {
            max_cpus   = 4
            max_memory = 8.GB
            max_time   = 2.h
        }
    }

    // Docker
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false

        process {
            withName: FASTP                         { container = "quay.io/biocontainers/fastp:1.0.1--heae3180_0" }
            withName: 'BOWTIE2_HOST_REMOVE|BOWTIE2_MAP' { container = "biocontainers/bowtie2:v2.4.1_cv1" }
            withName: MEGAHIT                       { container = "nanozoo/megahit:1.2.9--8f39288" }
            withName: 'JGI_DEPTH|METABAT2'          { container = "metabat/metabat:latest" }
            withName: MAXBIN2                       { container = "nanozoo/maxbin2:2.2.7--b643a6d" }
            withName: CONCOCT                       { container = "quay.io/biocontainers/concoct:1.1.0--py38h8c62d01_2" }
            withName: DASTOOL                       { container = "quay.io/biocontainers/das_tool:1.1.6--r42hdfd78af_0" }
            withName: CHECKM2                       { container = "quay.io/biocontainers/checkm2:1.1.0--pyh7e72e81_1" }
            withName: GTDBTK                        { container = "ecogenomic/gtdbtk:2.4.1" }
        }
    }

    // Singularity
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "$HOME/.singularity/cache"
        docker.enabled         = false

        process {
            withName: FASTP                         { container = "${projectDir}/containers/fastp.sif" }
            withName: 'BOWTIE2_HOST_REMOVE|BOWTIE2_MAP' { container = "${projectDir}/containers/bowtie2_samtools.sif" }
            withName: MEGAHIT                       { container = "${projectDir}/containers/megahit.sif" }
            withName: 'JGI_DEPTH|METABAT2'          { container = "${projectDir}/containers/metabat2.sif" }
            withName: MAXBIN2                       { container = "${projectDir}/containers/maxbin2.sif" }
            withName: CONCOCT                       { container = "${projectDir}/containers/concoct.sif" }
            withName: DASTOOL                       { container = "${projectDir}/containers/das_tool.sif" }
            withName: CHECKM2                       { container = "${projectDir}/containers/checkm2.sif" }
            withName: GTDBTK                        { container = "${projectDir}/containers/gtdbtk.sif" }
        }
    }
}

// Conda settings
conda {
    enabled       = false
    useMamba      = true
    createTimeout = '1 h'
    cacheDir      = "${HOME}/.nextflow/conda"
}

// Reports
report {
    enabled   = true
    overwrite = true
    file      = "${params.output_dir}/reports/execution_report.html"
}

timeline {
    enabled   = true
    overwrite = true
    file      = "${params.output_dir}/reports/execution_timeline.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "${params.output_dir}/reports/execution_trace.txt"
}

dag {
    enabled   = true
    overwrite = true
    file      = "${params.output_dir}/reports/pipeline_dag.svg"
}

// Manifest
manifest {
    name            = 'MAG-pipeline'
    description     = 'Metagenome-Assembled Genome binning pipeline with multi-binner refinement'
    mainScript      = 'main.nf'
    nextflowVersion = '>=22.04.0'
    version         = '2.0.0'
}
